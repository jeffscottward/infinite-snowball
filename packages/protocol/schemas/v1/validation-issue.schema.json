{
  "$id": "https://schemas.infinite-snowball.local/protocol/1.0.0/validation-issue.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "maxProperties": 8,
  "properties": {
    "allowed": {},
    "assetId": {
      "maxLength": 161,
      "minLength": 1,
      "type": "string"
    },
    "observed": {},
    "package": {
      "maxLength": 161,
      "minLength": 1,
      "type": "string"
    },
    "path": {
      "maxLength": 161,
      "minLength": 1,
      "type": "string"
    },
    "remediation": {
      "maxLength": 161,
      "minLength": 1,
      "type": "string"
    },
    "ruleId": {
      "enum": [
        "E_CACHE_WRITE",
        "E_CATALOG_STALE",
        "E_CODEC_UNSUPPORTED",
        "E_CODE_FORBIDDEN",
        "E_DAG_CYCLE",
        "E_DEPENDENCY_EXACT",
        "E_ENGINE_RANGE",
        "E_FILE_BUDGET",
        "E_GLB_REFERENCE",
        "E_HASH_MISMATCH",
        "E_LICENSE_POLICY",
        "E_LOCK_MISMATCH",
        "E_MIGRATION",
        "E_MIME_MISMATCH",
        "E_NPM_PROVENANCE",
        "E_OFFLINE_MISSING_ASSET",
        "E_OPTIONAL_PEER_CONFLICT",
        "E_PACKAGE_WITHDRAWN",
        "E_PATH_POLICY",
        "E_PRIVACY_EGRESS",
        "E_QUOTA",
        "E_SAVE_EXPORT_INTEGRITY",
        "E_SAVE_EXPORT_SIZE",
        "E_SAVE_EXPORT_VERSION",
        "E_SCHEMA_STRICT",
        "E_TRANSACTION_STATE"
      ],
      "type": "string"
    },
    "validatorVersion": {
      "const": "1.0.0",
      "type": "string"
    }
  },
  "required": [
    "ruleId",
    "path",
    "observed",
    "allowed",
    "validatorVersion",
    "remediation"
  ],
  "title": "Infinite Snowball validation-issue protocol 1.0.0",
  "type": "object"
}
